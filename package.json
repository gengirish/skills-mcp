{
  "name": "@gengirish/skills-mcp",
  "version": "0.1.0",
  "description": "MCP server that lets any AI agent discover, search, and install agent skills from across the GitHub ecosystem (Anthropic, Superpowers, wshobson, antigravity, Composio, and ~7,000 more).",
  "type": "module",
  "bin": {
    "skills-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "data/catalog.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:catalog": "node scripts/build-catalog.mjs",
    "build": "tsc -p tsconfig.json && node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "prepare": "npm run build && node -e \"const fs=require('fs');if(!fs.existsSync('data/catalog.json'))console.error('NOTE: data/catalog.json missing; run npm run build:catalog')\"",
    "dev": "node --import tsx --watch src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build:catalog && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "cursor",
    "agent-skills",
    "skills",
    "ai",
    "anthropic",
    "llm-tools"
  ],
  "author": "gengirish",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gengirish/skills-mcp.git"
  },
  "homepage": "https://github.com/gengirish/skills-mcp#readme",
  "bugs": {
    "url": "https://github.com/gengirish/skills-mcp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fuse.js": "^7.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "gray-matter": "^4.0.3",
    "p-limit": "^6.2.0",
    "picomatch": "^4.0.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
